{
  "env": {
    "browser": true,
    "es2020": true
  },
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "script"
  },
  "extends": ["eslint:recommended", "prettier"],
  "rules": {
    "no-var": "error",
    "prefer-const": "error",
    "no-unused-vars": "warn",
    "eqeqeq": ["error", "always"],
    "no-redeclare": "error",
    "no-floating-decimal": "error"
  },
  "globals": {
    "QRCode": "readonly"
  }
}
